"stacked": true, "graph_span": "1y", "span": {"end": "month"}, "header": {"show": true, "title": "PND Historická Data (Měsíční agregace)"}, "series": [{"entity": "sensor.pnd_data", "name": "Výroba", "attribute": "production", "data_generator": "return entity.attributes.pnddate.map((pnd, index) => {\n  return [new Date(pnd).getTime(), entity.attributes.production[index]];\n});\n", "color": "var(--success-color)", "opacity": 0.8, "invert": false, "type": "column", "group_by": {"func": "sum", "duration": "1month"}}, {"entity": "sensor.pnd_data", "name": "Spotřeba", "attribute": "consumption", "data_generator": "return entity.attributes.pnddate.map((pnd, index) => {\n  return [new Date(pnd).getTime(), entity.attributes.consumption[index]];\n});\n", "color": "var(--error-color)", "opacity": 0.8, "invert": true, "type": "column", "group_by": {"func": "sum", "duration": "1month"}}]}]}, {"path": "default_view", "title": "Home", "cards": [{"type": "vertical-stack", "cards": [{"type": "glance", "title": "Pritomnost doma", "entities": [{"entity": "device_tracker.iphone_19", "name": "Kamil"}, {"entity": "device_tracker.unifi_default_c2_eb_91_20_3b_6d", "name": "Romana"}, {"entity": "device_tracker.unifi_default_de_f6_6b_c7_67_74", "name": "Nela"}, {"entity": "device_tracker.unifi_default_0e_c7_df_8a_66_f9", "name": "Adela"}], "state_color": true, "show_name": true, "show_state": true}]}, {"type": "thermostat", "entity": "climate.topeni"}, {"type": "vertical-stack", "cards": [{"type": "markdown", "content": "### Vytapeni\n\n{% set s = states(\"sensor.heating_manager_status\") %}\n{% set a = state_attr(\"sensor.heating_manager_status\", \"last_action\") %}\n{% set t = state_attr(\"sensor.heating_manager_status\", \"last_action_time\") %}\n**{{ s }}**\n\n| | |\n|:--|--:|\n| Obyvak | **{{ states(\"sensor.teplota_obyvak_temperature\") }}C** |\n| TC cil | {{ state_attr(\"climate.topeni\", \"temperature\") | default(\"?\") }}C |\n| Venkovni | {{ states(\"sensor.venkovni_teplota_temperature\") }}C |\n| Bojler | {% if states(\"switch.tepelnecerpadlo_3w_teplavoda\") == \"on\" %}aktivni{% else %}-{% endif %} |\n\n*{{ a | default(\"\") }} ({{ t | default(\"\") }})*"}, {"type": "glance", "title": "Pritomnost", "entities": [{"entity": "device_tracker.iphone_19", "name": "Kamil"}, {"entity": "device_tracker.unifi_default_c2_eb_91_20_3b_6d", "name": "Romana"}, {"entity": "device_tracker.unifi_default_de_f6_6b_c7_67_74", "name": "Nela"}, {"entity": "device_tracker.unifi_default_0e_c7_df_8a_66_f9", "name": "Adela"}], "state_color": true}, {"type": "markdown", "content": "### Daikin podkrovi\n\n| Mistnost | Teplota | Cil | Stav | Osoba |\n|:---------|--------:|----:|:-----|:------|\n| Adela | {{ states(\"sensor.adela_pokoj_temperature\") }}C | {{ state_attr(\"climate.adela_pokoj_room_temperature\", \"temperature\") | default(\"-\") }}C | {{ states(\"climate.adela_pokoj_room_temperature\") }} | {% if states(\"device_tracker.unifi_default_0e_c7_df_8a_66_f9\") == \"home\" %}doma{% else %}pryc{% endif %} |\n| Nela | {{ states(\"sensor.nela_pokoj_temperature\") }}C | {{ state_attr(\"climate.nela_pokoj_room_temperature\", \"temperature\") | default(\"-\") }}C | {{ states(\"climate.nela_pokoj_room_temperature\") }} | {% if states(\"device_tracker.unifi_default_de_f6_6b_c7_67_74\") == \"home\" %}doma{% else %}pryc{% endif %} |\n| Pracovna | {{ states(\"sensor.2_temperature\") }}C | {{ state_attr(\"climate.pracovna_room_temperature\", \"temperature\") | default(\"-\") }}C | {{ states(\"climate.pracovna_room_temperature\") }} | {% if states(\"device_tracker.iphone_19\") == \"home\" %}doma{% else %}pryc{% endif %} |"}, {"type": "markdown", "content": "### Plan 12h\n\n{% set sched = state_attr(\"sensor.heating_manager_schedule\", \"schedule\") %}\n{% if sched and sched | length > 0 %}\n| Cas | Udalost | TC | Duvod |\n|:----|:--------|---:|:------|\n{% for e in sched[:8] %}| {{ e.time | default(\"?\") }} | {{ e.event | default(\"?\") }} | {{ e.tc_target | default(\"?\") }}C | {{ e.reason | default(\"\") }} |\n{% endfor %}\n{% else %}\n*Sestavuji plan...*\n{% endif %}"}, {"type": "markdown", "content": "### Log 24h\n\n{% set log = state_attr(\"sensor.heating_manager_log\", \"log\") %}\n{% if log and log | length > 0 %}\n| Cas | Zarizeni | Popis |\n|:----|:---------|:------|\n{% for e in log[:8] %}| {{ e.time | default(\"?\") }} | {{ e.device | default(\"?\") }} | {{ e.description | default(\"\") | truncate(50) }} |\n{% endfor %}\n{% else %}\n*Zadne akce*\n{% endif %}"}, {"type": "entities", "title": "Ovladani", "entities": [{"entity": "input_boolean.summer_mode", "name": "Letni rezim"}, {"entity": "input_number.topeni_target_temp", "name": "Cil doma"}, {"entity": "input_number.topeni_away_temp", "name": "Cil pryc"}]}]}, {"type": "entities", "entities": [{"entity": "switch.brana"}, {"entity": "switch.tasmota"}, {"entity": "input_boolean.ohrev_vody_switch"}, {"entity": "switch.tepelnecerpadlo_topeni"}, {"entity": "switch.tepelnecerpadlo_3w_topeni"}, {"entity": "switch.tepelnecerpadlo_3w_teplavoda"}, {"entity": "switch.tepelnecerpadlo_bojler"}, {"entity": "switch.spinac_bazen2"}], "title": "Brana", "show_header_toggle": false}, {"type": "markdown", "content": "### Vzorce pritomnosti\n\n{% set a = state_attr(\"sensor.presence_patterns\", \"persons\") %}\n{% if a %}\n\n| Osoba | Odchod Po-Pa | Prichod | Cest |\n|:------|:------------:|:-------:|:----:|\n{% for name in [\"Kamil\", \"Romana\", \"Nela\", \"Adela\"] %}{% set p = a.get(name, {}) if a.get is defined else a[name] if name in a else none %}{% if p %}| {{ name }} | {% if p.get(\"mostly_home\", \"no\") == \"yes\" %}doma{% else %}{{ p.get(\"morning_departure\", \"-\") }}{% endif %} | {% if p.get(\"mostly_home\", \"no\") == \"yes\" %}-{% else %}{{ p.get(\"afternoon_return\", \"-\") }}{% endif %} | {{ p.get(\"workday_trips\", 0) }} |\n{% endif %}{% endfor %}\n\n{% if state_attr(\"sensor.presence_patterns\", \"learning\") == \"yes\" %}*Ucim se... ({{ state_attr(\"sensor.presence_patterns\", \"data_days\") | default(0) }}/28 dni)*\n{% endif %}*{{ state_attr(\"sensor.presence_patterns\", \"updated\") | default(\"\") }}*\n{% else %}\n*Nacitam...*\n{% endif %}"}, {"type": "entities", "entities": [{"entity": "sensor.teplota_bojler_temperature", "name": "Horní"}, {"entity": "sensor.teplota_bojler_spodni_teplota", "name": "Spodní"}], "title": "Teplota_bojler"}, {"type": "entity", "entity": "sensor.battery_state_of_capacity", "name": "Stav baterie", "icon": "mdi:battery-80"}, {"type": "entities", "title": "Teplota a Vlhkost v Pokojích", "entities": [{"entity": "sensor.teplota_adam_pokoj_temperature_2", "name": "Adamův pokoj"}, {"entity": "sensor.teplota_nela_pokoj_temperature_4", "name": "Nela pokoj"}, {"entity": "sensor.teplota_adela_pokoj_temperature_3", "name": "Adéla pokoj"}, {"entity": "sensor.obyvak_temperature", "name": "Obývák"}, {"entity": "sensor.schodiste_temperature", "name": "Schodiště"}, {"entity": "sensor.teplota_loznice_teplota", "name": "Ložnice"}, {"entity": "sensor.teplota_koupelna_temperature", "name": "Horní koupelna"}]}, {"type": "weather-forecast", "entity": "weather.forecast_home", "show_forecast": false}, {"type": "entities", "entities": ["sensor.zasuvka_kotelna_ups_power_factor", {"entity": "sensor.zasuvka_kotelna_ups_summation_delivered", "name": "Dodáno shrnutí"}, {"entity": "sensor.zasuvka_kotelna_ups_active_power", "name": "Napájení"}, {"entity": "sensor.zasuvka_kotelna_ups_rms_voltage", "name": "Napětí"}, {"entity": "sensor.zasuvka_kotelna_ups_rms_current", "name": "Proud"}], "title": "Zasuvka_kotelna_UPS"}, {"type": "entities", "entities": [{"entity": "sensor.shellyem3_34945475ecce_channel_a_current", "name": "Channel A current"}, {"entity": "sensor.shellyem3_34945475ecce_channel_a_energy", "name": "Channel A energy"}, {"entity": "sensor.shellyem3_34945475ecce_channel_a_power", "name": "Channel A power"}, {"entity": "sensor.shellyem3_34945475ecce_channel_b_current", "name": "Channel B current"}, {"entity": "sensor.shellye
{"version": 1, "minor_version": 1, "key": "lovelace.lovelace", "data": {"config": {"title": "Domov", "views": [{"title": "Ovládání topení", "path": "ovladani-topeni", "icon": "mdi:hvac", "cards": [{"type": "custom:power-flow-card-plus", "entities": {"grid": {"entity": "sensor.power_meter_active_power", "invert_state": true, "name": "Sit", "color": {"consumption": "#db4437", "production": "#0f9d58"}, "secondary_info": {"entity": "sensor.shelly_3em_daily_energy", "unit_of_measurement": "kWh", "decimals": 1, "template": "TC: {{ state }} kWh"}}, "solar": {"entity": "sensor.inverter_input_power", "name": "FVE", "color": "#f4b400", "display_zero": true, "secondary_info": {"entity": "sensor.inverter_daily_yield", "unit_of_measurement": "kWh", "decimals": 1, "template": "Dnes: {{ state }} kWh"}}, "battery": {"entity": "sensor.battery_charge_discharge_power", "state_of_charge": "sensor.battery_state_of_capacity", "name": "Baterie", "color": {"consumption": "#db4437", "production": "#0f9d58"}, "secondary_info": {"entity": "sensor.battery_day_charge", "unit_of_measurement": "kWh", "decimals": 1, "template": "+{{ state }}/{{ states['sensor.battery_day_discharge'].state }} kWh"}}, "home": {"entity": "sensor.consumption_home_total", "override_state": true, "name": "Dum", "color": "#4285f4", "secondary_info": {"entity": "sensor.tepelne_cerpadlo_cas_v_provozu", "unit_of_measurement": "h", "decimals": 1, "template": "TC: {{ state }}h"}}}, "kw_decimals": 1, "min_flow_rate": 0.75, "max_flow_rate": 6, "w_decimals": 0, "watt_threshold": 0, "clickable_entities": true, "display_zero_lines": {"mode": "show", "transparency": 50}}, {"type": "thermostat", "entity": "climate.topeni"}, {"type": "custom:apexcharts-card", "graph_span": "24h", "header": {"show": true, "title": "Teploty obývák – 24h"}, "series": [{"entity": "sensor.teplota_obyvak_temperature", "name": "Čidlo 1 (orig)", "type": "line", "color": "#ff6b6b", "stroke_width": 1, "opacity": 0.5}, {"entity": "sensor.obyvak2_temperature", "
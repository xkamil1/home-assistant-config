 { width: 100% !important; }\nha-markdown th, ha-markdown td { padding: 4px 8px !important; border-color: rgba(0,180,216,0.1) !important; }\n"}, "content": "<div style='color:#00b4d8;font-size:11px;font-weight:700;letter-spacing:1px;margin-bottom:8px;'>API STATISTIKY</div>\n\n| | |\n|:--|--:|\n| Sonnet | **{{ state_attr('sensor.ai_agent_stats','calls_sonnet') | default(0) }}x** |\n| Haiku | **{{ state_attr('sensor.ai_agent_stats','calls_haiku') | default(0) }}x** |\n| Tokeny in | {{ state_attr('sensor.ai_agent_stats','tokens_in') | default(0) }} |\n| Tokeny out | {{ state_attr('sensor.ai_agent_stats','tokens_out') | default(0) }} |\n| Session | <span style='color:#ffd166;'>${{ state_attr('sensor.ai_agent_stats','total_cost_session_usd') | default(0) }}</span> |\n| Zustatek | <span style='color:#06d6a0;'>${{ state_attr('sensor.ai_agent_stats','estimated_remaining_usd') | default(0) }}</span> |\n| Zbyva | ~{{ state_attr('sensor.ai_agent_stats','estimated_remaining_queries') | default(0) }} dotazu |\n| Prumer | ${{ state_attr('sensor.ai_agent_stats','avg_cost_per_query_usd') | default(0) }} |"}]}]}]}, {"title": "Faktury", "path": "faktury", "icon": "mdi:file-document", "cards": [{"type": "horizontal-stack", "cards": [{"type": "custom:button-card", "entity": "sensor.neuhrazene_faktury", "name": "Neuhrazene", "show_state": true, "show_icon": true, "icon": "mdi:file-document-alert", "styles": {"card": [{"background": "#1a1a2e"}, {"border": "1px solid rgba(0,180,216,0.2)"}, {"border-radius": "12px"}, {"padding": "16px"}, {"height": "120px"}], "icon": [{"color": "#00b4d8"}, {"width": "36px"}], "name": [{"color": "#8892a4"}, {"font-size": "12px"}], "state": [{"color": "#e0e0e0"}, {"font-size": "28px"}, {"font-weight": "bold"}]}}, {"type": "custom:button-card", "entity": "sensor.faktury_k_uhrade_celkem", "name": "Celkem k uhrade", "show_state": true, "show_icon": true, "icon": "mdi:cash", "styles": {"card": [{"background": "#1a1a2e"}, {"border": "1px solid rgba(0,180,216,0.2)
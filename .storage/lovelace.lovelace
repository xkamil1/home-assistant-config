"}]}, {"type": "custom:button-card", "entity": "climate.pracovna_room_temperature", "name": "Pracovna", "layout": "vertical", "show_state": true, "show_label": true, "label": "[[[\n  return `Aktuálně: ${states['sensor.2_temperature'].state} °C`;\n]]]\n", "tap_action": {"action": "more-info"}, "styles": {"card": [{"border-radius": "12px"}, {"padding": "16px"}, {"font-size": "18px"}, {"color": "white"}, {"background-color": "[[[\n  if (entity.state == 'cool') return 'rgba(0, 120, 255, 0.8)';\n  if (entity.state == 'heat') return 'rgba(255, 60, 60, 0.8)';\n  return 'rgba(30,30,30,0.7)';\n]]]\n"}], "name": [{"font-weight": "bold"}], "label": [{"font-size": "14px"}, {"padding-top": "4px"}]}, "state": [{"value": "cool", "icon": "mdi:snowflake"}, {"value": "heat", "icon": "mdi:fire"}, {"value": "off", "icon": "mdi:power"}]}]}]}, {"type": "panel", "path": "spotreba-elektriny", "title": "Spotřeba elektřiny", "cards": [{"type": "vertical-stack", "cards": [{"type": "custom:apexcharts-card", "graph_span": "24h", "span": {"end": "hour"}, "header": {"show": true, "title": "Výkon po fázích (kW)"}, "now": {"show": true}, "apex_config": {"stroke": {"width": 1.5}, "yaxis": {"tickAmount": 10, "labels": {"formatter": "EVAL:(val) => `${val.toFixed(1)}`\n"}, "title": {"text": "Výkon (kW)"}}, "annotations": {"yaxis": [{"y": 0, "borderColor": "#888", "label": {"text": "0 kW", "style": {"color": "#888", "fontSize": "12px", "fontWeight": "bold", "background": "transparent"}}}]}}, "series": [{"entity": "sensor.power_meter_phase_a_active_power", "name": "Fáze A", "color": "red", "group_by": {"duration": "5min", "func": "avg"}, "transform": "return x / 1000;"}, {"entity": "sensor.power_meter_phase_b_active_power", "name": "Fáze B", "color": "green", "group_by": {"duration": "5min", "func": "avg"}, "transform": "return x / 1000;"}, {"entity": "sensor.power_meter_phase_c_active_power", "name": "Fáze C", "color": "blue", "group_by": {"duration": "5min", "func": "avg"}, "transform": "return x / 1000;"}]}, {"type": "history-graph", "title": "Stav zařízení", "hours_to_show": 24, "refresh_interval": 60, "entities": [{"entity": "switch.tepelnecerpadlo_topeni", "name": "TČ Topení"}, {"entity": "switch.tepelnecerpadlo_bojler", "name": "TČ Bojler"}, {"entity": "switch.spinac_bazen2"}]}, {"type": "custom:apexcharts-card", "header": {"title": "Stav baterie (%)", "show": true}, "graph_span": "24h", "span": {"end": "hour"}, "apex_config": {"yaxis": {"min": 0, "max": 100, "decimalsInFloat": 0, "title": {"text": "Kapacita (%)"}, "labels": {"formatter": "EVAL:(val) => `${val.toFixed(0)} %`\n"}}}, "series": [{"entity": "sensor.battery_state_of_capacity", "name": "Stav baterie", "color": "#00bcd4", "type": "line", "stroke_width": 2, "group_by": {"duration": "5min", "func": "avg"}}]}]}]}, {"title": "Energy Planer", "path": "predpoved-vyroby", "cards": [{"type": "vertical-stack", "cards": [{"type": "markdown", "content": "## Predpoved FVE\n\n{% set c = states(\"sensor.solar_confidence_now\") | int(0) %}\n{% set ct = states(\"sensor.solar_confidence_tomorrow\") | int(0) %}\n{% set kwh = state_attr(\"sensor.solar_confidence_tomorrow\", \"forecast_solar_kwh\") | float(0) %}\n\n**Dnes: {{ c }}%** (Met.no: {{ state_attr(\"sensor.solar_confidence_now\", \"metno_avg\") }}% | OWM: {{ state_attr(\"sensor.solar_confidence_now\", \"owm_avg\") }}%)\n\n**Zitra: {{ ct }}% | {{ kwh }} kWh**\n\n{{ state_attr(\"sensor.solar_confidence_tomorrow\", \"recommendation\") }}"}, {"type": "markdown", "content": "### Hodinovy prehled\n\n{% set hourly = state_attr(\"sensor.solar_confidence_now\", \"hourly\") %}\n{% if hourly %}\n\n| Hod | Met.no | OWM | % |\n|:---:|--------|-----|--:|\n{% for h in hourly %}| **{{ h.hour }}** | {{ h.condition_metno }} | {{ h.condition_owm }} | {{ h.confidence }}% |\n{% endfor %}\n{% else %}\n*Cekam...*\n{% endif %}\n\n*{{ state_attr(\"sensor.solar_confidence_now\", \"updated\") }}*"}]}, {"type": "vertical-stack", "cards": [{"type": "markdown", "content": "## Nabijeni Elroq\n\n{% set r = states.sensor.energy_planner_recommendation %}\n{% set a = r.attributes if r else none %}\n{% if a %}\nSOC: **{{ a.ev_soc_now | float(0) }}%** | Dojezd: {{ a.ev_range_now | float(0) | round(0) }} km\n\n**{{ r.state }}**\n\n{% if a.reason is defined %}{{ a.reason }}{% endif %}\n{% else %}\n*Cekam...*\n{% endif %}"}, {"type": "markdown", "content": "### Vyhled nabijeni\n\n{% set strat = state_attr(\"sensor.energy_planner_recommendation\", \"strategy\") %}\n{% if strat %}**{% if strat == \"wait_for_fve\" %}Cekam na FVE{% elif strat == \"charge_for_gap\" %}Nabijim na mezeru{% elif strat == \"wait_for_weekend\" %}Cekam na vikend{% elif strat == \"no_sun_window\" %}Zadne slunce v 5 dnech{% elif strat == \"critical_soc\" %}Kriticky SOC{% else %}{{ strat }}{% endif %}**\n\n{% endif %}{% set a = state_attr(\"sensor.energy_planner_recommendation\", \"outlook_5day\") %}\n{% if a and a | length > 0 %}\n\n| | Den | Km | SOC po | Podminky | kWh | Prebytek |\n|:--|:----|---:|------:|:---------|----:|---------:|\n{% for d in a %}| {% if d.charge_needed == \"critical\" %}🔴{% elif d.charge_needed == \"recommended\" %}🟡{% elif d.charge_needed == \"optional\" %}🔵{% else %}🟢{% endif %} | {% if d.is_weekend == \"yes\" %}**{% endif %}{{ d.day_name | default(\"?\") }}{% if d.is_sunny == \"yes\" %} 🌞{% endif %}{% if d.is_weekend == \"yes\" %}**{% endif %} | {{ d.km_expected | default(0) | round(0) }} | {{ d.soc_after | default(\"?\") }}% | {{ d.condition | default(\"?\") }} {{ d.solar_confidence | default(0) }}% | {{ d.expected_kwh | default(0) }} | {% if d.surplus_for_ev_kwh | default(\"0\") | float > 0 %}+{{ d.surplus_for_ev_kwh }}{% else %}-{% endif %} |\n{% endfor %}\n\n🔴 Kriticky | 🟡 Doporuceno | 🔵 Volitelne | 🟢 OK\n\nCelkem prebytek: {{ state_attr(\"sensor.energy_planner_recommendation\", \"total_surplus_5day\") | default(\"0\") }} kWh\n{% else %}\n*Nacitam vyhled...*\n{% endif %}"}, {"type": "entities", "entities": [{"entity": "input_text.energy_planner_user_request", "name": "Instrukce"}, {"entity": "input_number.ev_target_soc_tomorrow", "name": "Cilovy SOC"}, {"entity": "input_boolean.ev_nocharge_tonight", "name": "Nenabjet v noci"}]}]}]}, {"title": "Spotreba", "path": "spotreba", "cards": [{"type": "vertical-stack", "cards": [{"type": "markdown", "content": "## Spotreba domacnosti\n\n{% set h = states(\"sensor.consumption_home_total\") | int(0) %}\n{% set fve = states(\"sensor.inverter_input_power\") | int(0) %}\n{% set grid = states(\"sensor.power_meter_active_power\") | int(0) %}\n{% set bat = states(\"sensor.battery_charge_discharge_power\") | int(0) %}\n{% set trk = states(\"sensor.consumption_tracked\") | int(0) %}\n{% set unt = states(\"sensor.consumption_untracked\") | int(0) %}\n{% set pct = state_attr(\"sensor.consumption_untracked\", \"percentage\") | int(0) %}\n\n**Celkem: {{ h }} W** | FVE: {{ fve }} W | {% if grid < 0 %}Ze site: {{ grid | abs }} W{% else %}Export: {{ grid }} W{% endif %} | Bat: {{ bat }} W\n\nSledovano: **{{ trk }} W** | Nesledovano: **{{ unt }} W** ({{ pct }}%)\n\n*{{ state_attr(\"sensor.consumption_home_total\", \"updated\") }}*"}, {"type": "markdown", "content": "### Rozklad spotreby\n\n{% set h = states(\"sensor.consumption_home_total\") | int(1) %}\n{% set tc = state_attr(\"sensor.consumption_tracked\", \"tc_total_w\") | int(0) %}\n{% set boj = state_attr(\"sensor.consumption_tracked\", \"bojler_spirala_w\") | int(0) %}\n{% set pr = state_attr(\"sensor.consumption_tracked\", \"pracka_w\") | int(0) %}\n{% set su = state_attr(\"sensor.consumption_tracked\", \"susicka_w\") | int(0) %}\n{% set dai = state_attr(\"sensor.consumption_tracked\", \"daikin_total_w\") | int(0) %}\n{% set evc = state_attr(\"sensor.consumption_tracked\", \"ev_charger_w\") | int(0) %}\n{% set ups = state_attr(\"sensor.consumption_tracked\", \"ups_w\") | int(0) %}\n{% set tv = state_attr(\"sensor.consumption_tracked\", \"tv_w\") | int(0) %}\n{% set unt = states(\"sensor.consumption_untracked\") | int(0) %}\n\n| Zarizeni | Faze | Vykon | % |\n|:---------|:----:|------:|--:|\n| TC | A+B+C | {{ tc }} W | {{ (tc / h * 100) | round(0) if h > 0 else 0 }}% |\n{% if boj > 0 %}| Spirala | B | {{ boj }} W | {{ (boj / h * 100) | round(0) }}% |\n{% endif %}| Pracka | C | {{ pr }} W | {{ (pr / h * 100) | round(0) if h > 0 else 0 }}% |\n| Susicka | C | {{ su }} W | {{ (su / h * 100) | round(0) if h > 0 else 0 }}% |\n| Daikin | C | {{ dai }} W* | {{ (dai / h * 100) | round(0) if h > 0 else 0 }}% |\n{% if evc > 0 %}| Wallbox | A+B+C | {{ evc }} W | {{ (evc / h * 100) | round(0) }}% |\n{% endif %}| UPS | ? | {{ ups }} W | {{ (ups / h * 100) | round(0) if h > 0 else 0 }}% |\n| TV | ? | {{ tv }} W | {{ (tv / h * 100) | round(0) if h > 0 else 0 }}% |\n| Nesledovano | - | {{ unt }} W | {{ (unt / h * 100) | round(0) if h > 0 else 0 }}% |"}, {"type": "markdown", "content": "### Faze\n\n{% set pa = state_attr(\"sensor.consumption_phase_imbalance\", \"phase_a_w\") | int(0) %}\n{% set pb = state_attr(\"sensor.consumption_phase_imbalance\", \"phase_b_w\") | int(0) %}\n{% set pc = state_attr(\"sensor.consumption_phase_imbalance\", \"phase_c_w\") | int(0) %}\n{% set imb = states(\"sensor.consumption_phase_imbalance\") | int(0) %}\n\n| Faze | Vykon | Smer |\n|:----:|------:|:-----|\n| **A** | {{ pa | abs }} W | {% if pa < 0 %}import{% else %}export{% endif %} |\n| **B** | {{ pb | abs }} W | {% if pb < 0 %}import{% else %}export{% endif %} |\n| **C** | {{ pc | abs }} W | {% if pc < 0 %}import{% else %}export{% endif %} |\n\nNerovnovaha: {% if imb < 500 %}OK{% elif imb < 2000 %}POZOR{% else %}VYSOKA{% endif %} **{{ imb }} W** (max: {{ state_attr(\"sensor.consumption_phase_imbalance\", \"most_loaded\") }})"}, {"type": "conditional", "conditions": [{"condition": "state", "entity": "input_boolean.phase_imbalance_alert", "state": "on"}], "card": {"type": "markdown", "content": "### ALERT: Nerovnovaha fazi > 10 min!\n\n**{{ states(\"sensor.consumption_phase_imbalance\") }} W**"}}]}]}, {"title": "AI Agent", "path": "ai-agent", "icon": "mdi:robot", "panel": true, "cards": [{"type": "vertical-stack", "cards": [{"type": "custom:stack-in-card", "mode": "horizontal", "card_mod": {"style": "ha-card { background: #16213e !important; border: 1px solid rgba(0,180,216,0.3) !important; border-radius: 12px !important; box-shadow: 0 4px 24px rgba(0,0,0,0.5) !important; }"}, "cards": [{"type": "entities", "entities": [{"entity": "input_text.ai_agent_request", "name": "AI Agent"}], "card_mod": {"style": "ha-card { background: transparent !important; box-shadow: none !important; border: none !important; }"}}, {"type": "custom:button-card", "entity": "input_button.ai_agent_confirm", "name": "Potvrdit", "icon": "mdi:check-circle", "show_name": true, "show_icon": true, "tap_action": {"action": "call-service", "service": "input_button.press", "service_data": {"entity_id": "input_button.ai_agent_confirm"}}, "styles": {"card": [{"width": "100px"}, {"min-width": "100px"}, {"height": "68px"}, {"background": "linear-gradient(135deg, #06d6a0 0%, #0077b6 100%)"}, {"border-radius": "10px"}, {"border": "none"}, {"box-shadow": "0 4px 15px rgba(6,214,160,0.4)"}, {"margin-left": "8px"}, {"flex-shrink": "0"}], "icon": [{"color": "white"}, {"width": "26px"}, {"margin-bottom": "2px"}], "name": [{"color": "white"}, {"font-size": "10px"}, {"font-weight": "700"}, {"text-transform": "uppercase"}]}}, {"type": "custom:button-card", "entity": "input_button.ai_agent_reject", "name": "Zamitnout", "icon": "mdi:close-circle", "show_name": true, "show_icon": true, "tap_action": {"action": "call-service", "service": "input_button.press", "service_data": {"entity_id": "input_button.ai_agent_reject"}}, "styles": {"card": [{"width": "100px"}, {"min-width": "100px"}, {"height": "68px"}, {"background": "linear-gradient(135deg, #ef476f 0%, #b5143b 100%)"}, {"border-radius": "10px"}, {"border": "none"}, {"box-shadow": "0 4px 15px rgba(239,71,111,0.4)"}, {"margin-left": "8px"}, {"flex-shrink": "0"}], "icon": [{"color": "white"}, {"width": "26px"}, {"margin-bottom": "2px"}], "name": [{"color": "white"}, {"font-size": "10px"}, {"font-weight": "700"}, {"text-transform": "uppercase"}]}}]}, {"type": "markdown", "card_mod": {"style": "ha-card { background: #1a1a2e !important; border: 1px solid rgba(0,180,216,0.15) !important; border-radius: 12px !important; box-shadow: 0 4px 24px rgba(0,0,0,0.5) !important; color: #e0e0e0 !important; }\n.card-content { padding: 12px 16px !important; }\nha-markdown { color: #e0e0e0 !important; }\nha-markdown pre { background: #0d0d1a !important; border: 1px solid rgba(0,180,216,0.15) !important; border-radius: 8px !important; padding: 12px !important; font-size: 12px !important; line-height: 1.6 !important; max-height: 300px !important; overflow-y: auto !important; }\nha-markdown table { width: 100% !important; }\nha-markdown th, ha-markdown td { padding: 4px 8px !important; border-color: rgba(0,180,216,0.1) !important; }\n"}, "content": "{% set p = states('sensor.ai_agent_pending') %}{% if p == 'waiting_confirmation' %}<div style='color:#ffd166;font-size:11px;font-weight:700;letter-spacing:1px;margin-bottom:8px;'>CEKA NA POTVRZENI</div>\n\n**{{ state_attr('sensor.ai_agent_pending','confirmation_prompt') | default('') }}**\n\n{% set steps = state_attr('sensor.ai_agent_pending','steps') %}{% if steps %}{% for step in steps %}<span style='color:#8892a4;'>{{ loop.index }}.</span> {{ step }}\n\n{% endfor %}{% endif %}{% elif p == 'executing' %}<div style='color:#00b4d8;font-weight:600;'>Provadim akce...</div>{% elif p == 'analyzing' %}<div style='color:#00b4d8;font-weight:600;'>Sonnet analyzuje...</div>{% else %}<span style='color:#8892a4;font-size:12px;'>Zadej instrukci a stiskni Potvrdit</span>{% endif %}"}, {"type": "markdown", "card_mod": {"style": "ha-card { background: #1a1a2e !important; border: 1px solid rgba(0,180,216,0.15) !important; border-radius: 12px !important; box-shadow: 0 4px 24px rgba(0,0,0,0.5) !important; color: #e0e0e0 !important; }\n.card-content { padding: 12px 16px !important; }\nha-markdown { color: #e0e0e0 !important; }\nha-markdown pre { background: #0d0d1a !important; border: 1px solid rgba(0,180,216,0.15) !important; border-radius: 8px !important; padding: 12px !important; font-size: 12px !important; line-height: 1.6 !important; max-height: 300px !important; overflow-y: auto !important; }\nha-markdown table { width: 100% !important; }\nha-markdown th, ha-markdown td { padding: 4px 8px !important; border-color: rgba(0,180,216,0.1) !important; }\n"}, "content": "<div style='color:#00b4d8;font-size:11px;font-weight:700;letter-spacing:1px;margin-bottom:8px;'>LIVE VYSTUP</div>\n\n```\n{% set msgs = state_attr('sensor.ai_agent_log','messages') %}{% if msgs %}{% for msg in msgs[-30:] %}{{ msg }}\n{% endfor %}{% else %}Cekam na instrukci...\n{% endif %}```\n<div style='color:#8892a4;font-size:10px;text-align:right;'>{{ state_attr('sensor.ai_agent_log','updated') | default('') }}</div>"}, {"type": "markdown", "card_mod": {"style": "ha-card { background: #1a1a2e !important; border: 1px solid rgba(0,180,216,0.15) !important; border-radius: 12px !important; box-shadow: 0 4px 24px rgba(0,0,0,0.5) !important; color: #e0e0e0 !important; } .card-content { padding: 12px 16px !important; }"}, "content": "<div style='color:#00b4d8;font-size:11px;font-weight:700;letter-spacing:1px;margin-bottom:8px;'>HISTORIE INSTRUKCI</div>\n\n{% set entries = state_attr('sensor.ai_agent_history','display') %}{% if entries %}{% for e in entries %}{{ e }}\n{% endfor %}{% else %}Zatim zadna historie...{% endif %}"}, {"type": "horizontal-stack", "cards": [{"type": "markdown", "card_mod": {"style": "ha-card { background: #1a1a2e !important; border: 1px solid rgba(0,180,216,0.15) !important; border-radius: 12px !important; box-shadow: 0 4px 24px rgba(0,0,0,0.5) !important; color: #e0e0e0 !important; }\n.card-content { padding: 12px 16px !important; }\nha-markdown { color: #e0e0e0 !important; }\nha-markdown pre { background: #0d0d1a !important; b
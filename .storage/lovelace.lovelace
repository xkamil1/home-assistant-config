mportant; padding: 6px 8px !important; border-bottom: 1px solid rgba(0,180,216,0.3) !important; } ha-markdown td { padding: 6px 8px !important; border-bottom: 1px solid rgba(0,180,216,0.1) !important; }"}, "content": "## Neuhrazene faktury\n\n{% set inv = state_attr('sensor.faktury_detail', 'invoices') %}{% if inv and inv | length > 0 %}| Dodavatel | Castka | VS | Splatnost | Dnu |\n|:----------|-------:|:---|:----------|----:|\n{% for i in inv %}| {{ i.supplier[:25] }} | {{ '{:,.0f}'.format(i.amount) }} Kc | {{ i.variable_symbol }} | {{ i.due_date }} | {% if i.overdue %}<span style='color:#ef476f;'>**{{ i.days_left }}**</span>{% elif i.days_left <= 2 %}<span style='color:#ffd166;'>{{ i.days_left }}</span>{% else %}{{ i.days_left }}{% endif %} |\n{% endfor %}{% else %}Zadne neuhrazene faktury{% endif %}"}, {"type": "markdown", "card_mod": {"style": "ha-card { background: #1a1a2e !important; border: 1px solid rgba(0,180,216,0.15) !important; border-radius: 12px !important; color: #8892a4 !important; } .card-content { padding: 12px 16px !important; }"}, "content": "*Aktualizace kazdou hodinu | [Sprava faktur](http://10.0.0.55)*"}]}, {"title": "Heating Report", "path": "heating-report", "icon": "mdi:chart-bar", "panel": true, "cards": [{"type": "vertical-stack", "cards": [{"type": "horizontal-stack", "cards": [{"type": "entity", "entity": "input_select.heating_report_week", "name": "Tyden"}, {"type": "button", "entity": "input_button.heating_report_generate", "name": "Generovat", "icon": "mdi:refresh", "tap_action": {"action": "toggle"}, "show_name": true, "show_icon": true}, {"type": "entity", "entity": "sensor.heating_weekly_report", "attribute": "total_kwh", "name": "kWh", "suffix": " kWh", "icon": "mdi:lightning-bolt"}, {"type": "entity", "entity": "sensor.heating_weekly_report", "attribute": "total_cost_czk", "name": "Naklady", "suffix": " Kc", "icon": "mdi:currency-usd"}, {"type": "entity", "entity": "sensor.heating_weekly_report", "attribute": "avg_outdoor_temp"